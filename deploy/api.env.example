# Wheat Harvester API — PRODUCTION environment template.
# Copy to apps/api/.env on the server and fill in real values. Never commit it.
#   cp deploy/api.env.example apps/api/.env && nano apps/api/.env

# ---- Server ----
PORT=3000
NODE_ENV=production

# Origins allowed to call the API directly. The web admin is same-origin (served
# by nginx) so it needs no entry. '*' is fine when the API is only public via
# nginx; otherwise list the exact origins (comma-separated).
CORS_ORIGINS=*

# ---- MySQL ----
# The database and tables are created automatically on first boot, so the user
# must be able to CREATE DATABASE (or pre-create it and GRANT ALL on it).
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=myharvester
MYSQL_PASSWORD=__set_a_strong_password__
MYSQL_DATABASE=myharvester_prod

# ---- Auth ----
# MUST be a long random string. Generate with:  openssl rand -hex 32
JWT_SECRET=__change_me__
JWT_EXPIRES_IN=7d

# ---- Platform operator (super admin) ----
# Seeded on a fresh DB; this is the login for the WEB ADMIN CONSOLE.
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=__set_a_strong_password__
SUPER_ADMIN_NAME=Platform Admin

# ---- Subscriptions ----
# Free-trial length (days) granted to newly onboarded owners.
SUBSCRIPTION_TRIAL_DAYS=365

# ---- Outbound email (optional; leave blank to disable) ----
# Used to email new owners their login credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Wheat Harvester <no-reply@yourdomain.com>

# ---- Optional dev OWNER seed (for mobile testing on a fresh DB) ----
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_NAME=
