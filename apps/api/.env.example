# Copy to .env and fill in. Never commit the real .env.

# Server
PORT=3000
NODE_ENV=development

# CORS — comma separated origins allowed to call the API (Expo dev, etc.)
CORS_ORIGINS=*

# MySQL connection. The database + tables are auto-created on startup.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=wheat_harvester

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Bootstrap the first SUPER_ADMIN on startup if no admin exists
BOOTSTRAP_ADMIN_EMAIL=owner@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_NAME=Owner
